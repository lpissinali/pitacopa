<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Seed Test Data — PitaCopa</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" href="/img/logo-icon-dark.png" type="image/png">
  <meta name="theme-color" content="#0f172a">
  <link rel="stylesheet" href="css/style.css">
  <style>
    body { max-width: 680px; margin: 60px auto; padding: 0 20px; font-family: system-ui, sans-serif; }
    h1 { font-size: 24px; font-weight: 800; margin-bottom: 8px; }
    p  { color: #666; font-size: 14px; margin-bottom: 24px; }
    .log { background: #0f1117; color: #a3e635; font-family: monospace; font-size: 13px;
           padding: 16px; border-radius: 8px; min-height: 160px; white-space: pre-wrap;
           line-height: 1.6; margin-top: 20px; }
    .warning { background: #fef9c3; border: 1px solid #fde047; border-radius: 8px;
                padding: 14px 18px; margin-bottom: 20px; font-size: 13px; color: #854d0e; }
    button { padding: 12px 28px; font-size: 15px; font-weight: 700; border-radius: 8px;
              border: none; cursor: pointer; background: #f5a623; color: #02091b; }
    button:disabled { opacity: .5; cursor: not-allowed; }
    .btn-danger { background: #dc2626; color: #fff; margin-left: 12px; }
  </style>
</head>
<body>
  <h1>🌱 Seed Test Data</h1>
  <div class="warning">
    ⚠️ <strong>Dev only.</strong> This page writes fake users directly to Firestore.
    Use it locally to populate the ranking and profile pages for testing.
    Do not deploy this page to production (it's already in .gitignore).
  </div>

  <p>
    Creates <strong>8 fake user profiles</strong> in the <code>users</code> collection
    plus <code>bolao_participants</code> entries with varied points so the ranking
    page has data to display. Real Firebase Auth accounts are <em>not</em> created —
    only Firestore documents.
  </p>

  <button id="btnSeed">🌱 Seed 8 test profiles</button>
  <button id="btnClear" class="btn-danger">🗑️ Clear seeded data</button>

  <div class="log" id="log">Waiting…</div>

<script type="module">
import { db } from './js/config.js';
import {
  doc, setDoc, deleteDoc, collection, getDocs, query, where
} from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

const log = document.getElementById('log');
function print(msg) { log.textContent += msg + '\n'; }
function clear()    { log.textContent = ''; }

// ── Test profiles ─────────────────────────────────────────────────────────
const SEED_PROFILES = [
  {
    uid: 'seed_001', name: 'Rei do Pitaco',  country: 'BR',
    photoURL: 'https://api.dicebear.com/7.x/avataaars/svg?seed=rei',
    points: 0, exactScores: 0,
  },
  {
    uid: 'seed_002', name: 'Messi Fan Club', country: 'AR',
    photoURL: 'https://api.dicebear.com/7.x/avataaars/svg?seed=messi',
    points: 0, exactScores: 0,
  },
  {
    uid: 'seed_003', name: 'Zé Futebol',     country: 'BR',
    photoURL: '',
    points: 0, exactScores: 0,
  },
  {
    uid: 'seed_004', name: 'CR7 Forever',    country: 'PT',
    photoURL: 'https://api.dicebear.com/7.x/avataaars/svg?seed=cr7',
    points: 0, exactScores: 0,
  },
  {
    uid: 'seed_005', name: 'Soccerhead',     country: 'US',
    photoURL: 'https://api.dicebear.com/7.x/avataaars/svg?seed=soc',
    points: 0, exactScores: 0,
  },
  {
    uid: 'seed_006', name: 'La Pulga',       country: 'MX',
    photoURL: '',
    points: 0, exactScores: 0,
  },
  {
    uid: 'seed_007', name: 'GolAlemania',    country: 'DE',
    photoURL: 'https://api.dicebear.com/7.x/avataaars/svg?seed=ger',
    points: 0, exactScores: 0,
  },
  {
    uid: 'seed_008', name: 'ChampionsQueen', country: 'GB',
    photoURL: 'https://api.dicebear.com/7.x/avataaars/svg?seed=uk',
    points: 0, exactScores: 0,
  },
];

// A shared bolão so the ranking table in profile.html has data too
const SEED_BOLAO_ID  = 'seed_bolao_001';
const SEED_BOLAO_DOC = {
  name: 'Bolão de Teste',
  description: 'Dados de demonstração',
  inviteCode: 'TEST01',
  createdBy: 'seed_001',
  createdByName: 'Rei do Pitaco',
  participantCount: SEED_PROFILES.length,
};

document.getElementById('btnSeed').addEventListener('click', async () => {
  const btn = document.getElementById('btnSeed');
  btn.disabled = true;
  clear();
  print('Starting seed…\n');

  try {
    // Write the bolão
    await setDoc(doc(db, 'boloes', SEED_BOLAO_ID), SEED_BOLAO_DOC);
    print(`✅ Created bolão: "${SEED_BOLAO_DOC.name}" (${SEED_BOLAO_ID})`);

    for (const p of SEED_PROFILES) {
      // User document
      await setDoc(doc(db, 'users', p.uid), {
        name:      p.name,
        country:   p.country,
        email:     `${p.uid}@test.pitacopa.dev`,
        photoURL:  p.photoURL,
        nameChanges: 1,      // already "used" their name change
        _seed: true,
      });
      print(`✅ User: ${p.name} (${p.country})`);

      // bolao_participants entry (for per-bolão ranking)
      await setDoc(doc(db, 'bolao_participants', `${SEED_BOLAO_ID}_${p.uid}`), {
        uid:         p.uid,
        bolaoId:     SEED_BOLAO_ID,
        name:        p.name,
        photoURL:    p.photoURL,
        points:      p.points,
        exactScores: p.exactScores,
        _seed: true,
      });
      print(`   └─ bolão participant: ${p.points} pts / ${p.exactScores} exatos`);
    }

    print('\n🎉 Done! Open /ranking to see the leaderboard.');
    print('   The profiles also appear in the Meus Bolões tab if you join the test bolão.');
  } catch(e) {
    print('\n❌ Error: ' + e.message);
    console.error(e);
  }
  btn.disabled = false;
});

document.getElementById('btnClear').addEventListener('click', async () => {
  if (!confirm('Delete all seeded test data from Firestore?')) return;
  const btn = document.getElementById('btnClear');
  btn.disabled = true;
  clear();
  print('Clearing seeded data…\n');

  try {
    for (const p of SEED_PROFILES) {
      await deleteDoc(doc(db, 'users', p.uid));
      print(`🗑️  Deleted user: ${p.name}`);
      await deleteDoc(doc(db, 'bolao_participants', `${SEED_BOLAO_ID}_${p.uid}`));
      print(`   └─ Deleted participant`);
    }
    await deleteDoc(doc(db, 'boloes', SEED_BOLAO_ID));
    print(`🗑️  Deleted bolão: ${SEED_BOLAO_ID}`);
    print('\n✅ All seeded data removed.');
  } catch(e) {
    print('\n❌ Error: ' + e.message);
    console.error(e);
  }
  btn.disabled = false;
});
</script>
</body>
</html>
