});

// ‚ĒÄ‚ĒÄ GROUPS TAB ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
window._loadGroups = async function() {
  if (groupsLoaded) return;
  groupsLoaded = true;
  try {
    // Fetch my participations + tournament results in parallel
    const [mySnap, resultsSnap] = await Promise.all([
      getDocs(query(collection(db, 'bolao_participants'), where('uid', '==', currentUser.uid))),
      getDoc(doc(db, 'settings', 'results')),
    ]);
    const myParticipations = mySnap.docs.map(d => d.data());

    // Tournament actual results for tiebreaker
    const results      = resultsSnap.exists() ? resultsSnap.data() : {};
    const actualChamp  = results.champion  || '';
    const actualRunner = results.runnerUp  || '';

    document.getElementById('groupsLoader').style.display = 'none';

    if (myParticipations.length === 0) {
      document.getElementById('groupsEmpty').style.display = 'block';
      return;
    }

    const groupList = document.getElementById('groupsList');
    groupList.style.display = 'block';

    for (const p of myParticipations) {
      const bolaoSnap = await getDoc(doc(db, 'boloes', p.bolaoId));
      if (!bolaoSnap.exists()) continue;
      const bolao = bolaoSnap.data();

      // Fetch participants + bol√£o predictions in parallel for this bol√£o
      const [partSnap, bolPredSnap] = await Promise.all([
        getDocs(query(collection(db, 'bolao_participants'), where('bolaoId', '==', p.bolaoId))),
        getDocs(query(collection(db, 'bolao_predictions'), where('bolaoId', '==', p.bolaoId))),
      ]);

      // Index predictions by uid for tiebreaker lookup
      const predsByUid = {};
      bolPredSnap.forEach(d => { predsByUid[d.data().uid] = d.data(); });

      const all = partSnap.docs.map(d => d.data()).sort((a, b) => {
        if ((b.points||0) !== (a.points||0)) return (b.points||0) - (a.points||0);
        if ((b.exactScores||0) !== (a.exactScores||0)) return (b.exactScores||0) - (a.exactScores||0);
        if ((b.correctResults||0) !== (a.correctResults||0)) return (b.correctResults||0) - (a.correctResults||0);
        const aChamp = actualChamp && predsByUid[a.uid]?.champion === actualChamp ? 1 : 0;
        const bChamp = actualChamp && predsByUid[b.uid]?.champion === actualChamp ? 1 : 0;
        if (bChamp !== aChamp) return bChamp - aChamp;
        const aRunner = actualRunner && predsByUid[a.uid]?.runnerUp === actualRunner ? 1 : 0;
        const bRunner = actualRunner && predsByUid[b.uid]?.runnerUp === actualRunner ? 1 : 0;
        if (bRunner !== aRunner) return bRunner - aRunner;
        return (a.name||'').localeCompare(b.name||'');
      });
      const myRank  = all.findIndex(x => x.uid === currentUser.uid) + 1;
      const myEntry = all.find(x => x.uid === currentUser.uid);

      // Mini ranking rows
      const rankRows = all.map((x, i) => {
        const isMe  = x.uid === currentUser.uid;
        const medal = i === 0 ? 'ūü•á' : i === 1 ? 'ūü•ą' : i === 2 ? 'ūü•Č' : (i+1);
        return `<tr class="${isMe ? 'me-row' : ''}">
          <td style="text-align:center;width:36px;">${medal}</td>
          <td>${x.name || 'An√īnimo'}${isMe ? ' <span style="font-size:11px;color:var(--gold);">(voc√™)</span>' : ''}</td>
          <td style="text-align:center;font-size:12px;color:var(--muted);">${x.exactScores||0} ‚úď</td>
          <td style="text-align:right;font-weight:700;color:var(--gold-d);">${x.points||0} pts</td>
        </tr>`;
      }).join('');

      const inviteCode = bolao.inviteCode || '';
      const inviteLink = `${window.location.origin}/bolao?id=${p.bolaoId}`;

      const card = document.createElement('div');
      card.className = 'bolao-card';
      card.innerHTML = `
        <div class="bolao-card-header">
          <div>
            <h4 style="font-size:15px;font-weight:700;margin-bottom:4px;">${bolao.name}</h4>
            <p style="font-size:13px;color:var(--muted);">
              ${bolao.description ? bolao.description + ' ¬∑ ' : ''}${all.length} ${t('label_participant_s')}${all.length!==1?'s':''}
            </p>
          </div>
          <div style="display:flex;align-items:center;gap:10px;flex-shrink:0;">
            <div style="text-align:center;">
              <div style="font-size:24px;font-weight:800;color:var(--gold);">${myRank > 0 ? '#'+myRank : '‚ÄĒ'}</div>
              <div style="font-size:11px;color:var(--muted);">${t('label_position')}</div>
            </div>
            <div style="text-align:center;margin-right:4px;">
              <div style="font-size:16px;font-weight:700;">${myEntry ? (myEntry.points||0) : 0}</div>
              <div style="font-size:11px;color:var(--muted);">pts</div>
            </div>
            <div style="display:flex;flex-direction:column;gap:6px;">
              <a href="bolao?id=${p.bolaoId}" class="btn btn-primary btn-sm">
                <i data-lucide="arrow-right" width="13" height="13"></i> ${t('dash_view')}
              </a>
              ${inviteCode ? `<button class="btn btn-ghost btn-sm copy-invite-btn" data-code="${inviteCode}" data-link="${inviteLink}" data-name="${bolao.name}">
                <i data-lucide="share-2" width="13" height="13"></i> ${t('btn_invite')}
              </button>` : ''}
              <button class="leave-btn" data-bolao-id="${p.bolaoId}" data-bolao-name="${bolao.name}">${t('btn_signout_short')}</button>
            </div>
          </div>
        </div>
        <div class="bolao-card-ranking">
          <div class="bolao-card-ranking-label">${t('pool_ranking_label')}</div>
          <table class="mini-rank-table"><tbody>${rankRows}</tbody></table>
        </div>
      `;
      groupList.appendChild(card);
    }

    // Invite / share handler
    groupList.querySelectorAll('.copy-invite-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const code = btn.dataset.code;
        const link = btn.dataset.link;
        const name = btn.dataset.name;
        const shareText = `Entre no meu bol√£o da Copa 2026 "${name}"!\nC√≥digo: ${code}\nLink: ${link}`;
        if (navigator.share) {
          navigator.share({ title: 'PitaCopa 2026', text: shareText, url: link }).catch(()=>{});
        } else {
          navigator.clipboard.writeText(shareText).then(() => {
            const orig = btn.innerHTML;
            btn.textContent = '‚úÖ Copiado!';
            setTimeout(() => { btn.innerHTML = orig; if(window.lucide) lucide.createIcons(); }, 2000);
          });
        }
      });
    });

    // Leave bol√£o handler
    groupList.querySelectorAll('.leave-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const bId   = btn.dataset.bolaoId;
        const bName = btn.dataset.bolaoName;
        if (!confirm(`Sair do bol√£o "${bName}"? Seus palpites ser√£o removidos.`)) return;
        try {
          await deleteDoc(doc(db, 'bolao_participants', `${bId}_${currentUser.uid}`));
          await deleteDoc(doc(db, 'bolao_predictions',  `${bId}_${currentUser.uid}`));
          btn.closest('.bolao-card').remove();
          if (groupList.children.length === 0) {
            groupList.style.display = 'none';
            document.getElementById('groupsEmpty').style.display = 'block';
          }
        } catch(e) { alert('Erro ao sair: ' + e.message); }
      });
    });

    if (window.lucide) lucide.createIcons();
  } catch(e) {
    console.error(e);
    document.getElementById('groupsLoader').style.display = 'none';
    document.getElementById('groupsEmpty').style.display = 'block';
  }
};

// ‚ĒÄ‚ĒÄ PREDICTIONS TAB ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
const STAGE_LABELS_PRED = {
  'group':        { pt:'Fase de Grupos',   en:'Group Stage'    },
  'round32':      { pt:'Rodada de 32',     en:'Round of 32'    },
  'round16':      { pt:'Oitavas de Final', en:'Round of 16'    },
  'quarterfinal': { pt:'Quartas de Final', en:'Quarter-Finals' },
  'semifinal':    { pt:'Semifinais',       en:'Semi-Finals'    },
  'third_place':  { pt:'3¬ļ Lugar',         en:'Third Place'    },
  'final':        { pt:'Final',            en:'Final'          },
};

const TOURNAMENT_START = new Date('2026-06-11T00:00:00');

let activeStage = 'all';

window._loadPreds = async function() {
  if (predsLoaded) return;
  predsLoaded = true;

  try {
    const predSnap = await getDoc(doc(db, 'user_predictions', currentUser.uid));
    if (predSnap.exists()) userPreds = predSnap.data();

    // Populate champion / runner-up selects
    const allTeams = Object.values(typeof WC2026_TEAMS !== 'undefined' ? WC2026_TEAMS : {}).flat();
    const champSel = document.getElementById('pickChampion');
    const runSel   = document.getElementById('pickRunner');
    const blankOpt = `<option value="">‚ÄĒ ${t('btn_select')} ‚ÄĒ</option>`;
    champSel.innerHTML = blankOpt;
    runSel.innerHTML   = blankOpt;
    allTeams.forEach(tm => {
      const name = tm.name;
      const opt  = `<option value="${tm.id}">${name}</option>`;  // no flag in option text (renders as "BR" on Windows)
      champSel.innerHTML += opt;
      runSel.innerHTML   += opt;
    });

    // Flag span update helpers (uses flag-icons via flagHtml())
    function updateTeamFlag(selectEl, spanId, defaultHtml) {
      const team = allTeams.find(t => t.id === selectEl.value);
      document.getElementById(spanId).innerHTML = team ? flagHtml(team.flag) : defaultHtml;
    }
    champSel.addEventListener('change', () => updateTeamFlag(champSel, 'champFlag', 'ūüŹÜ'));
    runSel.addEventListener('change',   () => updateTeamFlag(runSel,   'runnerFlag', 'ūü•ą'));

    if (userPreds.champion) { champSel.value = userPreds.champion; updateTeamFlag(champSel, 'champFlag', 'ūüŹÜ'); }
    if (userPreds.runnerUp) { runSel.value   = userPreds.runnerUp; updateTeamFlag(runSel,   'runnerFlag', 'ūü•ą'); }
    // topScorer value is restored inside buildPlayerOptions

    // Populate artilheiro dropdown ‚ÄĒ merge static list + Firestore extras
    if (typeof buildPlayerOptions === 'function') {
      let extraPlayers = [];
      try {
        const extSnap = await getDoc(doc(db, 'settings', 'players_extra'));
        if (extSnap.exists()) extraPlayers = extSnap.data().players || [];
      } catch(e) { /* non-fatal ‚ÄĒ extras simply won't appear */ }
      buildPlayerOptions(document.getElementById('pickTopScorer'), lang, userPreds.topScorer || '', extraPlayers);
    }

    // Tournament start lock
    const tournamentStarted = new Date() >= TOURNAMENT_START;
    if (tournamentStarted) {
      ['pickChampion','pickRunner','pickTopScorer'].forEach(id => {
        const el = document.getElementById(id);
        if (el) { el.disabled = true; }
      });
      const champSection = document.querySelector('.champ-picks').closest('.settings-card');
      if (champSection && !champSection.querySelector('.tournament-lock-note')) {
        const note = document.createElement('div');
        note.className = 'alert alert-warning tournament-lock-note';
        note.style.marginTop = '12px';
        note.innerHTML = 'ūüĒí O torneio j√° come√ßou. As escolhas de Campe√£o, Vice e Artilheiro est√£o bloqueadas.';
        champSection.appendChild(note);
      }
    }

    // Build stage filter buttons
    const stageFilter = document.getElementById('stageFilter');
    const stageKeys   = ['all', 'group', 'round32', 'round16', 'quarterfinal', 'semifinal', 'third_place', 'final'];
    stageKeys.forEach(s => {
      const btn = document.createElement('button');
      btn.className = 'group-filter-btn' + (s === 'all' ? ' active' : '');
      btn.textContent = s === 'all'
        ? t('label_all')
        : (STAGE_LABELS_PRED[s] ? STAGE_LABELS_PRED[s][lang] : s);
      btn.addEventListener('click', () => {
        stageFilter.querySelectorAll('.group-filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeStage = s;
        renderGames();
      });
      stageFilter.appendChild(btn);
    });

    document.getElementById('predsLoader').style.display   = 'none';
    document.getElementById('predsContent').style.display  = 'block';
    document.getElementById('predsSaveBar').style.display  = 'block';
    renderGames();
    if (window.lucide) lucide.createIcons();
  } catch(e) {
    console.error(e);
    document.getElementById('predsLoader').innerHTML =
      '<div style="text-align:center;padding:40px;color:var(--muted);">Erro ao carregar palpites. Tente recarregar a p√°gina.</div>';
  }
};

function renderGames() {
  const container = document.getElementById('gamesContainer');
  container.innerHTML = '';
  const now   = new Date();
  const games = (typeof ALL_GAMES !== 'undefined') ? ALL_GAMES : [];

  if (games.length === 0) {
    container.innerHTML = '<div style="text-align:center;padding:32px;color:var(--muted);">Nenhum jogo dispon√≠vel.</div>';
    return;
  }

  const filtered = activeStage === 'all' ? games : games.filter(g => g.stage === activeStage);

  // Group by stage + group
  const sections     = {};
  const sectionOrder = [];
  filtered.forEach(g => {
    const key = g.stage === 'group' ? 'group_' + (g.group || '') : g.stage;
    if (!sections[key]) { sections[key] = []; sectionOrder.push(key); }
    sections[key].push(g);
  });

  let totalPred = 0, totalGames = 0;

  sectionOrder.forEach(key => {
    const gamesInSection = sections[key];
    let sectionLabel = '';
    if (key.startsWith('group_')) {
      const grp = key.replace('group_', '');
      sectionLabel = t('label_group') + ' ' + grp;
    } else {
      sectionLabel = STAGE_LABELS_PRED[key] ? STAGE_LABELS_PRED[key][lang] : key;
    }

    const header = document.createElement('div');
    header.className = 'stage-header';
    header.innerHTML = `<i data-lucide="flag" width="14" height="14"></i> ${sectionLabel}`;
    container.appendChild(header);

    gamesInSection.forEach(game => {
      totalGames++;
      const gameDate = new Date(game.date);
      const isLocked = now >= gameDate;
      const pred     = userPreds.games && userPreds.games[game.id];
      if (pred && pred.home !== undefined && pred.home !== '') totalPred++;

      const homeName = game.homeName || game.home;
      const awayName = game.awayName || game.away;
      const homeFlag = game.homeFlag || 'ūüŹ≥';
      const awayFlag = game.awayFlag || 'ūüŹ≥';
      const dateStr  = gameDate.toLocaleDateString('pt-BR', { month:'short', day:'numeric' });
      const timeStr  = gameDate.toLocaleTimeString('pt-BR', { hour:'2-digit', minute:'2-digit' });

      const homeVal = pred && pred.home !== undefined ? pred.home : '';
      const awayVal = pred && pred.away !== undefined ? pred.away : '';

      const row = document.createElement('div');
      row.className = 'game-pred-row' + (isLocked ? ' locked' : '');
      row.innerHTML = `
        <div class="game-date">${dateStr}<br><small>${timeStr}</small></div>
        <div class="game-teams">
          <div class="game-team-stack">
            <div class="game-team">
              <span class="game-flag">${flagHtml(homeFlag)}</span>
              <span class="game-team-name">${homeName}</span>
            </div>
            <div class="game-team">
              <span class="game-flag">${flagHtml(awayFlag)}</span>
              <span class="game-team-name">${awayName}</span>
            </div>
          </div>
          <div class="score-inputs">
            <input type="number" class="score-input" min="0" max="99"
              value="${homeVal}" data-game="${game.id}" data-side="home"
              ${isLocked ? 'disabled' : ''} placeholder="‚ÄĒ"
              oninput="if(this.value.length>2)this.value=this.value.slice(0,2)">
            <span class="score-sep">√ó</span>
            <input type="number" class="score-input" min="0" max="99"
              value="${awayVal}" data-game="${game.id}" data-side="away"
              ${isLocked ? 'disabled' : ''} placeholder="‚ÄĒ"
              oninput="if(this.value.length>2)this.value=this.value.slice(0,2)">
          </div>
        </div>
        ${isLocked ? '<span class="lock-badge"><i data-lucide="lock" width="11" height="11"></i> Bloqueado</span>' : ''}
      `;
      container.appendChild(row);
    });
  });

  document.getElementById('predProgress').textContent = `${totalPred}/${totalGames} ` + t('label_filled');

  // Track changes
  container.querySelectorAll('.score-input').forEach(input => {
    input.addEventListener('change', () => {
      const gId = input.dataset.game;
      const side = input.dataset.side;
      const val  = parseInt(input.value);
      if (!userPreds.games) userPreds.games = {};
      if (!userPreds.games[gId]) userPreds.games[gId] = {};
      userPreds.games[gId][side] = isNaN(val) ? '' : val;
      // Update progress
      let filled = 0, total = 0;
      (typeof ALL_GAMES !== 'undefined' ? ALL_GAMES : []).forEach(g => {
        total++;
        const p = userPreds.games[g.id];
        if (p && p.home !== undefined && p.home !== '') filled++;
      });
      document.getElementById('predProgress').textContent = `${filled}/${total} ` + t('label_filled');
    });
  });

  if (window.lucide) lucide.createIcons();
}

// ‚ĒÄ‚ĒÄ Save predictions ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
document.getElementById('btnSavePreds').addEventListener('click', async () => {
  try {
    userPreds.champion  = document.getElementById('pickChampion').value;
    userPreds.runnerUp  = document.getElementById('pickRunner').value;
    userPreds.topScorer = document.getElementById('pickTopScorer').value.trim();
    userPreds.updatedAt = serverTimestamp();
    await setDoc(doc(db, 'user_predictions', currentUser.uid), userPreds, { merge: true });
    showToast(t('toast_preds_saved'), 'success');
  } catch(e) {
    showToast(t('toast_save_error') + ' ' + e.message, 'error');
  }
});

// ‚ĒÄ‚ĒÄ Utility ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
function showAlert(containerId, msg, type) {
  const el = document.getElementById(containerId);
  if (!el) return;
  el.innerHTML = `<div class="alert alert-${type}">${msg}</div>`;
  setTimeout(() => { el.innerHTML = ''; }, 5000);
}

function showToast(msg, type = 'success') {
  let container = document.querySelector('.toast-container');
  if (!container) {
    container = document.createElement('div');
    container.className = 'toast-container';
    document.body.appendChild(container);
  }
  const toast = document.createElement('div');
  toast.className = `toast toast-${type}`;
  const icons = { success: '‚úÖ', error: '‚ĚĆ', info: '‚ĄĻÔłŹ' };
  toast.innerHTML = `<span>${icons[type] || 'ūüďĘ'}</span><span>${msg}</span>`;
  container.appendChild(toast);
  setTimeout(() => { toast.style.opacity = '0'; toast.style.transition = 'opacity 0.3s'; setTimeout(() => toast.remove(), 300); }, 4000);
}
</script>

