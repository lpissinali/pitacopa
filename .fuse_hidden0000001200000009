onAuthStateChanged(auth, async (user) => {
  if (!user) { window.location.href = 'login'; return; }
  currentUser = user;
  await loadUser();
  // If a tab was activated via URL hash before the module was ready, load its data now
  const activeTab = document.querySelector('.profile-tab-btn.active')?.dataset.tab;
  if (activeTab === 'preds')  window._loadPreds  && window._loadPreds();
  if (activeTab === 'groups') window._loadGroups && window._loadGroups();
});

async function loadUser() {
  try {
    const snap = await getDoc(doc(db, 'users', currentUser.uid));
    if (snap.exists()) {
      userData = snap.data();
    } else {
      // Auto-create a minimal users doc so the user appears in the ranking
      const initialData = {
        name: currentUser.displayName || currentUser.email?.split('@')[0] || 'Usu√°rio',
        email: currentUser.email || '',
        country: '',
        photoURL: currentUser.photoURL || '',
        nameChanges: 0,
        createdAt: serverTimestamp(),
      };
      await setDoc(doc(db, 'users', currentUser.uid), initialData);
      userData = initialData;
    }

    const name    = userData.name || currentUser.displayName || 'Usu√°rio';
    const email   = currentUser.email || '';
    const photo   = userData.photoURL || currentUser.photoURL || '';
    const country = userData.country || '';

    document.getElementById('headerName').textContent  = name;
    document.getElementById('headerEmail').textContent = email;
    const navUserName = document.getElementById('navUserName');
    if (navUserName) navUserName.textContent = name;
    document.getElementById('inputName').value         = name;
    document.getElementById('inputEmail').value        = email;
    if (country) {
      document.getElementById('inputCountry').value = country;
      const found = ALL_COUNTRIES.find(([c]) => c === country);
      if (found) document.getElementById('countryFlagDisplay').innerHTML = flagHtml(found[1]);
    }

    // Name change policy: can change once
    if ((userData.nameChanges || 0) >= 1) {
      lockNameField();
    } else {
      // Show "you can change once" hint
      const nameInput = document.getElementById('inputName');
      if (!nameInput.parentElement.querySelector('.name-change-note')) {
        const note = document.createElement('span');
        note.className = 'form-note name-change-note';
        note.textContent = '‚ĄĻÔłŹ Voc√™ pode alterar seu nome de exibi√ß√£o uma vez.';
        nameInput.parentElement.appendChild(note);
      }
    }

    const av = document.getElementById('avatarCircle');
    const initial = (name || email || '?').charAt(0).toUpperCase();
    if (photo) {
      av.innerHTML = `<img src="${photo}" alt="avatar" onerror="this.parentElement.textContent='${initial}'">`;
    } else {
      av.textContent = initial;
    }

    // Show password card only for email/password users (not Google, etc.)
    const providers = (currentUser.providerData || []).map(p => p.providerId);
    const isEmailUser = providers.includes('password') || (!providers.includes('google.com') && providers.length === 0);
    if (isEmailUser) {
      document.getElementById('passwordCard').style.display = 'block';
    }

    if (window.lucide) lucide.createIcons();
  } catch(e) { console.error(e); }
}

// ‚ĒÄ‚ĒÄ Save profile ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
document.getElementById('btnSaveProfile').addEventListener('click', async () => {
  const name    = document.getElementById('inputName').value.trim();
  const country = document.getElementById('inputCountry').value;
  if (!name) { showAlert('profileAlert', 'Por favor insira seu nome.', 'error'); return; }

  const currentName  = userData.name || currentUser.displayName || '';
  const nameChanged  = name !== currentName;
  const changeCount  = userData.nameChanges || 0;

  if (nameChanged && changeCount >= 1) {
    showAlert('profileAlert',
      '‚ĚĆ Voc√™ j√° usou sua altera√ß√£o de nome. N√£o √© poss√≠vel alterar o nome novamente.',
      'error');
    return;
  }

  try {
    await updateProfile(currentUser, { displayName: name });
    const updateData = {
      name, country,
      email: currentUser.email || '',
      photoURL: currentUser.photoURL || '',
      updatedAt: serverTimestamp(),
    };
    if (nameChanged) {
      updateData.nameChanges = changeCount + 1;
      userData.nameChanges   = changeCount + 1;
    }
    await setDoc(doc(db, 'users', currentUser.uid), updateData, { merge: true });
    userData.name = name;
    document.getElementById('headerName').textContent = name;

    if (nameChanged && userData.nameChanges >= 1) lockNameField();

    showToast(t('toast_profile_saved'), 'success');
  } catch(e) {
    showToast('Erro: ' + e.message, 'error');
  }
});

// ‚ĒÄ‚ĒÄ Change password ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
const btnChangePass = document.getElementById('btnChangePass');
if (btnChangePass) btnChangePass.addEventListener('click', async () => {
  const curr = document.getElementById('inputCurrPwd').value;
  const newP = document.getElementById('inputNewPwd').value;
  const conf = document.getElementById('inputConfPwd').value;
  if (!curr || !newP || !conf) { showAlert('profileAlert', 'Preencha todos os campos de senha.', 'error'); return; }
  if (newP !== conf) { showAlert('profileAlert', 'As senhas n√£o coincidem.', 'error'); return; }
  if (newP.length < 6) { showAlert('profileAlert', 'A nova senha deve ter pelo menos 6 caracteres.', 'error'); return; }
  try {
    const cred = EmailAuthProvider.credential(currentUser.email, curr);
    await reauthenticateWithCredential(currentUser, cred);
    await updatePassword(currentUser, newP);
    document.getElementById('inputCurrPwd').value = '';
    document.getElementById('inputNewPwd').value  = '';
    document.getElementById('inputConfPwd').value = '';
    showToast('Senha alterada com sucesso!', 'success');
  } catch(e) {
    const msg = e.code === 'auth/wrong-password' ? 'Senha atual incorreta.' : e.message;
    showToast('Erro: ' + msg, 'error');
  }
});

