rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────────────────
    // Public read: anyone can see the ranking (name, country, photoURL).
    // Write: only the owner can update their own profile.
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Bolões ────────────────────────────────────────────────────────────
    // Any authenticated user can read and create.
    // Only the creator can update or delete.
    match /boloes/{bolaoId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.createdBy;
    }

    // ── Bolão participants ─────────────────────────────────────────────────
    // Any authenticated user can read (needed for ranking + point aggregation).
    // Each participant can write their own entry; bolão creator can also write.
    match /bolao_participants/{partId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.uid;
    }

    // ── User predictions ──────────────────────────────────────────────────
    // Any authenticated user can read (needed for tiebreaker on ranking page).
    // Only the owner can write.
    match /user_predictions/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Bolão predictions ─────────────────────────────────────────────────
    // Any authenticated user can read (needed for bolão ranking tiebreaker).
    // Only the owner can write.
    match /bolao_predictions/{predId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.uid;
    }

    // ── Settings / tournament results ─────────────────────────────────────
    // Public read so ranking tiebreaker works even for unauthenticated visitors.
    // No client writes — update via Firebase console or Admin SDK only.
    match /settings/{document} {
      allow read:  if true;
      allow write: if false;
    }
  }
}
